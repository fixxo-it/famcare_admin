# ──────────────────────────────────────────────────
# Backend API base URL
# ──────────────────────────────────────────────────
# PICK ONE based on how you're testing:
#
# Browser on PC (npm run dev):
NEXT_PUBLIC_API_URL=http://localhost:8000/api
#
# Android Emulator:
# VITE_API_URL=http://10.0.2.2:8000/api
#
# Real phone via USB (replace with your PC's WiFi IP):
# VITE_API_URL=http://192.168.1.x:8000/api
#
# AWS ALB (production):
# NEXT_PUBLIC_API_URL=http://famcare-alb-1043123574.ap-south-1.elb.amazonaws.com/api

# ──────────────────────────────────────────────────
# WebSocket base URL (same host, NO /api prefix)
# ──────────────────────────────────────────────────
VITE_WS_URL=ws://localhost:8000
# VITE_WS_URL=ws://10.0.2.2:8000
# VITE_WS_URL=ws://192.168.1.x:8000
# VITE_WS_URL=ws://famcare-alb-1043123574.ap-south-1.elb.amazonaws.com
